<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lightGreenBg"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Profile"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/primaryGreen"/>

            <ImageView
                android:id="@+id/editProfileBtn"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/primaryGreen"/>
        </LinearLayout>

        <!-- NAME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/nameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="textPersonName"/>

        <!-- DOB -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Birth"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/dobTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="date"/>

        <!-- BLOOD GROUP -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Blood Group"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/bloodTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="text"/>

        <!-- ALLERGIES -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allergies"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/allergiesTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="70dp"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="textMultiLine"
            android:gravity="top"/>

        <!-- ADDRESS -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/addressTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="70dp"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="textPostalAddress"
            android:gravity="top"/>

        <!-- EMAIL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/emailTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="textEmailAddress"/>

        <!-- PHONE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone Number"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/phoneTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="phone"/>

        <!-- EMERGENCY SECTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Contact"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primaryGreen"
            android:layout_marginTop="28dp"/>

        <!-- EMERGENCY NAME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Name"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/emergencyNameTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="textPersonName"/>

        <!-- EMERGENCY PHONE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Phone"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/emergencyPhoneTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="phone"/>

        <!-- EMERGENCY EMAIL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Emergency Email"
            android:layout_marginTop="16dp"
            android:textStyle="bold"
            android:textColor="@color/textPrimary"/>

        <EditText
            android:id="@+id/emergencyEmailTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/rect_white"
            android:padding="12dp"
            android:enabled="false"
            android:importantForAutofill="no"
            android:inputType="textEmailAddress"/>

        <!-- SAVE BUTTON -->
        <Button
            android:id="@+id/saveProfileBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Profile"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/primaryGreen"
            android:textColor="@android:color/white"
            android:visibility="gone"/>

    </LinearLayout>
</ScrollView>
